# Supabase — from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
SUPABASE_SECRET_KEY=your-service-role-key  # SERVER ONLY — never expose to browser

# Razorpay — from your Razorpay dashboard
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-hmac-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx  # safe to expose for client-side checkout

# Resend — from your Resend dashboard (https://resend.com)
RESEND_API_KEY=re_xxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
